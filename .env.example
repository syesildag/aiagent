# Node.js Environment Configuration

# Application
NODE_ENV=development
PORT=3000
HOST=localhost
SERVER_TERMINATE_TIMEOUT=5000

# Database Configuration
DB_USER=your_db_user
DB_HOST=localhost
DB_NAME=your_database_name
DB_PASSWORD=your_db_password
DB_PORT=5432

# Database Pool Configuration (optional - defaults shown)
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=2000

# Security Configuration
HMAC_SECRET_KEY=your_hmac_secret_key_at_least_32_characters_long

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# OpenAI Configuration (when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com

# GitHub Copilot Configuration (when LLM_PROVIDER=github)
# OAuth authentication tokens (populated automatically after login)
AUTH_GITHUB_COPILOT={"type":"oauth","refresh":"","access":"","expires":0}
GITHUB_COPILOT_BASE_URL=https://models.inference.ai.azure.com
#GITHUB_COPILOT_BASE_URL=https://api.githubcopilot.com

# External APIs
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# MCP Configuration
MCP_SERVERS_PATH=./mcp-servers.json
MAX_LLM_ITERATIONS=2
# Maximum number of past conversations retained in memory/DB (default: 100).
# Oldest conversations are pruned when this limit is exceeded.
# MAX_CONVERSATIONS=100

# Maximum number of messages from the current conversation sent to the LLM per call.
# When unset (default), the full conversation history is forwarded and the provider's
# built-in token-budget logic (handleTokenLimits) trims it to fit the model's context window.
# Set to a positive integer to enforce a hard message-count limit regardless of token budget.
# CONVERSATION_HISTORY_WINDOW_SIZE=10