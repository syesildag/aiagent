{
  "servers": [
    {
      "name": "context7",
      "command": "./node_modules/.bin/context7-mcp",
      "args": [],
      "env": {},
      "enabled": true
    },
    {
      "name": "tavily-search",
      "command": "./node_modules/.bin/tavily-mcp",
      "args": [],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": true
    },
    {
      "name": "memory",
      "command": "node",
      "args": [
        "dist/src/mcp/server/memory.js"
      ],
      "enabled": true
    },
    {
      "name": "documentation",
      "command": "node",
      "args": [
        "dist/src/mcp/server/documentation.js"
      ],
      "enabled": true
    },
    {
      "name": "weather",
      "command": "node",
      "args": [
        "dist/src/mcp/server/weather.js"
      ],
      "enabled": true
    },
    {
      "name": "time",
      "command": "node",
      "args": [
        "dist/src/mcp/server/time.js"
      ],
      "enabled": true
    },
    {
      "name": "fetch",
      "command": "node",
      "args": [
        "dist/src/mcp/server/fetch.js"
      ],
      "enabled": true
    },
    {
      "name": "playwright",
      "command": "node",
      "args": [
        "./node_modules/@playwright/mcp/cli.js",
        "--browser", "chromium",
        "--headless"
      ],
      "env": {},
      "enabled": false
    },
    {
      "name": "jobs",
      "command": "node",
      "args": [
        "dist/src/mcp/server/jobs.js"
      ],
      "enabled": true
    },
    {
      "name": "google-messages",
      "protocol": "sse",
      "httpUrl": "http://localhost:7007/mcp",
      "env": {
        "OPENMESSAGES_PORT": "${OPENMESSAGES_PORT}"
      },
      "enabled": true
    }
  ]
}